    "cy:verify": "node scripts/cypress.js verify"
  },
  "devDependencies": {
    "cypress": "^14.5.4",
    "cypress-qase-reporter": "^3.6.0",
    "dotenv": "^16.4.7",
    "mocha": "^11.7.5"
  }
}
