{
  "name": "qase-termp-cypress",
  "version": "0.1.0",
  "private": true,
  "description": "Cypress functional test automation framework for stage.termp.com with optional Qase reporting.",
  "scripts": {
    "cy:open": "node scripts/cypress.js open",
